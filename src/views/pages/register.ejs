<%- include('../partials/head', { title }) %>

<section class="auth-shell">
  <article class="auth-card">
    <h1>Crear cuenta</h1>
    <p>Registrate para comentar en foros y acceder al proceso de compra.</p>

    <% if (notice) { %>
      <p class="form-notice"><%= notice %></p>
    <% } %>

    <% if (error) { %>
      <p class="form-error"><%= error %></p>
    <% } %>

    <form method="post" action="/registro" class="auth-form age-gate-form">
      <label for="username">Usuario</label>
      <input id="username" name="username" type="text" required minlength="3" value="<%= formData.username %>" />

      <label for="email">Email personal</label>
      <input id="email" name="email" type="email" required value="<%= formData.email %>" />

      <label for="phone">Teléfono WhatsApp</label>
      <div class="phone-row">
        <select id="countryCode" name="countryCode" required>
          <option value="+54" <%= formData.countryCode === '+54' ? 'selected' : '' %>>Argentina (+54)</option>
          <option value="+52" <%= formData.countryCode === '+52' ? 'selected' : '' %>>México (+52)</option>
          <option value="+57" <%= formData.countryCode === '+57' ? 'selected' : '' %>>Colombia (+57)</option>
          <option value="+56" <%= formData.countryCode === '+56' ? 'selected' : '' %>>Chile (+56)</option>
          <option value="+34" <%= formData.countryCode === '+34' ? 'selected' : '' %>>España (+34)</option>
          <option value="+1" <%= formData.countryCode === '+1' ? 'selected' : '' %>>EE. UU. / Canadá (+1)</option>
        </select>
        <input
          id="phone"
          name="phone"
          type="text"
          inputmode="numeric"
          required
          value="<%= formData.phone %>"
          placeholder="Número sin código país"
        />
      </div>
      <small class="input-help">Se guardará como número internacional (ej: +54911...).</small>

      <label for="password">Contraseña</label>
      <input id="password" name="password" type="password" required minlength="8" />

      <label class="inline-check" for="marketingOptIn">
        <input id="marketingOptIn" name="marketingOptIn" type="checkbox" <%= formData.marketingOptIn ? 'checked' : '' %> />
        Quiero recibir novedades por email (nuevos productos y reposición de stock).
      </label>

      <button type="submit" class="btn-primary" data-loading="Creando cuenta...">Crear cuenta</button>
    </form>

    <p class="auth-link-row">¿Ya tenés cuenta? <a href="/login">Ingresar</a></p>
  </article>
</section>

<%- include('../partials/age-gate') %>

<%- include('../partials/footer') %>
