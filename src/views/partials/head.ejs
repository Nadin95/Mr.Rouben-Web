<!doctype html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title><%= title %> | Mr. Rouben</title>
    <link rel="icon" type="image/png" href="/assets/logo.png" />
    <link rel="alternate icon" type="image/svg+xml" href="/assets/logo.svg" />
    <link rel="stylesheet" href="/css/styles.css" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Outfit:wght@400;600;800&family=Space+Grotesk:wght@500;700&display=swap"
      rel="stylesheet"
    />
  </head>
  <body>
    <header class="site-header">
      <nav class="nav-shell">
        <a class="brand" href="/">
          <img src="/assets/logo.png" alt="Mr. Rouben" onerror="this.src='/assets/logo.svg'" class="brand-logo" />
          <span>Mr. Rouben</span>
        </a>
        <a href="/checkout" class="nav-cart" aria-label="Ver carrito">
          <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <circle cx="9" cy="21" r="1"/><circle cx="20" cy="21" r="1"/>
            <path d="M1 1h4l2.68 13.39a2 2 0 0 0 2 1.61h9.72a2 2 0 0 0 2-1.61L23 6H6"/>
          </svg>
          <span id="cart-count" class="cart-count">0</span>
        </a>
        <button class="nav-menu-toggle" id="nav-menu-toggle" type="button" aria-controls="nav-panel" aria-expanded="false">
          Menú
        </button>
        <div class="nav-panel" id="nav-panel">
          <div class="nav-links">
            <a href="/">Inicio</a>
            <details class="nav-dropdown">
              <summary>Comprar</summary>
              <div class="nav-dropdown-panel">
                <a href="/catalogo">Todo el catálogo</a>
                <a href="/catalogo#tabaco">Tabaco</a>
                <a href="/catalogo#vapers">Vapers</a>
                <a href="/catalogo#parafernalia">Parafernalia</a>
              </div>
            </details>
            <a href="/foro">Comunidad</a>
            <% if (locals.currentUser?.role === 'admin') { %>
              <a href="/admin">Admin</a>
            <% } %>
          </div>
          <div class="auth-links">
            <% if (locals.currentUser) { %>
              <details class="nav-dropdown account-dropdown">
                <summary class="user-chip"><%= locals.currentUser.username %></summary>
                <div class="nav-dropdown-panel account-panel">
                  <a href="/mis-pedidos">Mis pedidos</a>
                  <a href="/checkout">Mi carrito</a>
                  <a href="/foro">Mis conversaciones</a>
                  <form method="post" action="/logout">
                    <button type="submit" class="ghost-btn">Salir</button>
                  </form>
                </div>
              </details>
            <% } else { %>
              <a href="/login" class="ghost-link">Ingresar</a>
              <a href="/registro" class="ghost-link">Crear cuenta</a>
            <% } %>
          </div>
        </div>
      </nav>
    </header>
    <main class="page-shell">
