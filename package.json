{
  "name": "mr-rouben-ecommerce",
  "version": "1.0.0",
  "description": "E-commerce de tabaco, vapers y parafernalia con Node.js, TypeScript, Express y MongoDB",
  "main": "dist/server.js",
  "scripts": {
    "dev": "nodemon",
    "build": "tsc",
    "start": "node dist/server.js",
    "start:prod": "npm run build && npx pm2 start ecosystem.config.cjs --env production",
    "seed:nadine": "ts-node src/scripts/seedNadine.ts",
    "seed:demo": "ts-node src/scripts/seedDemoData.ts"
  },
  "keywords": [
    "ecommerce",
    "express",
    "typescript",
    "mongodb"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "bcrypt": "^5.1.1",
    "cloudinary": "^1.41.3",
    "cookie-parser": "^1.4.7",
    "dotenv": "^16.4.5",
    "ejs": "^3.1.10",
    "express": "^4.19.2",
    "express-rate-limit": "^8.4.1",
    "helmet": "^8.1.0",
    "jsonwebtoken": "^9.0.2",
    "mongoose": "^8.5.1",
    "morgan": "^1.10.0",
    "multer": "^2.1.1",
    "multer-storage-cloudinary": "^4.0.0",
    "nodemailer": "^6.10.1",
    "qrcode-terminal": "^0.12.0",
    "whatsapp-web.js": "^1.34.6",
    "winston": "^3.19.0",
    "winston-daily-rotate-file": "^5.0.0"
  },
  "devDependencies": {
    "@types/bcrypt": "^5.0.2",
    "@types/cookie-parser": "^1.4.8",
    "@types/ejs": "^3.1.5",
    "@types/express": "^4.17.21",
    "@types/jsonwebtoken": "^9.0.6",
    "@types/morgan": "^1.9.9",
    "@types/multer": "^2.1.0",
    "@types/node": "^22.5.4",
    "@types/nodemailer": "^6.4.23",
    "@types/qrcode-terminal": "^0.12.2",
    "nodemon": "^3.1.4",
    "pm2": "^6.0.14",
    "ts-node": "^10.9.2",
    "typescript": "^5.5.4"
  }
}
