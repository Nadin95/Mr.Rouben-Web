<%- include('../partials/head', { title }) %>

<section class="auth-shell">
  <article class="auth-card">
    <% if (success) { %>
      <h1>¡Contraseña actualizada!</h1>
      <p class="form-notice">Tu contraseña fue cambiada correctamente. Ya podés iniciar sesión con la nueva contraseña.</p>
      <a href="/login" class="btn-primary" style="margin-top: 1rem; display: block; text-align: center;">Ir al login</a>

    <% } else { %>
      <h1>Nueva contraseña</h1>
      <p>Ingresá tu nueva contraseña. Debe tener al menos 8 caracteres.</p>

      <% if (error) { %>
        <p class="form-error"><%= error %></p>
      <% } %>

      <form method="post" action="/reset-password" class="auth-form">
        <input type="hidden" name="token" value="<%= token %>" />

        <label for="password">Nueva contraseña</label>
        <input id="password" name="password" type="password" required minlength="8" placeholder="Mínimo 8 caracteres" />

        <label for="passwordConfirm">Confirmá la contraseña</label>
        <input id="passwordConfirm" name="passwordConfirm" type="password" required minlength="8" placeholder="Repetí la contraseña" />

        <button type="submit" class="btn-primary" data-loading="Guardando...">Guardar nueva contraseña</button>
      </form>

      <p class="auth-link-row"><a href="/forgot-password">Solicitar nuevo enlace</a></p>
    <% } %>
  </article>
</section>

<%- include('../partials/age-gate') %>

<%- include('../partials/footer') %>
