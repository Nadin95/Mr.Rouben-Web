<%- include('../partials/head', { title }) %>

<section class="auth-shell">
  <article class="auth-card">
    <h1>¿Olvidaste tu contraseña?</h1>
    <p>Ingresá tu email registrado y te enviaremos un enlace para crear una nueva contraseña.</p>

    <% if (notice) { %>
      <p class="form-notice"><%= notice %></p>
    <% } %>

    <% if (error) { %>
      <p class="form-error"><%= error %></p>
    <% } %>

    <% if (!notice) { %>
      <form method="post" action="/forgot-password" class="auth-form">
        <label for="email">Email</label>
        <input id="email" name="email" type="email" required placeholder="tu@email.com" />

        <button type="submit" class="btn-primary" data-loading="Enviando...">Enviar enlace de recuperación</button>
      </form>
    <% } %>

    <p class="auth-link-row"><a href="/login">Volver al inicio de sesión</a></p>
  </article>
</section>

<%- include('../partials/age-gate') %>

<%- include('../partials/footer') %>
